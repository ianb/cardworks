{
  "name": "cardworks",
  "version": "0.1.0",
  "description": "TypeScript library for managing structured XML content with cards, references, versioning, and media support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./jsx/jsx-runtime": {
      "import": "./dist/jsx/jsx-runtime.js",
      "types": "./dist/jsx/jsx-runtime.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "tap",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "lint:oxlint": "oxlint -A no-unused-vars",
    "lint:knip": "knip",
    "lint:circular": "madge --circular --extensions ts src/",
    "prepare": "husky"
  },
  "keywords": [
    "xml",
    "cards",
    "references",
    "versioning"
  ],
  "license": "MIT",
  "dependencies": {
    "@xmldom/xmldom": "^0.9.8",
    "xpath-ts": "^1.3.13",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@ianbicking/personal-vibe-check": "file:../../personal-vibe-check",
    "@types/node": "^22.12.0",
    "eslint": "^9.19.0",
    "husky": "^9.1.7",
    "knip": "^5.83.1",
    "lint-staged": "^16.2.7",
    "madge": "^8.0.0",
    "oxlint": "^1.47.0",
    "tap": "^21.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.22.0"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint"
    ]
  },
  "engines": {
    "node": ">=20"
  }
}
